            "url": {
              "raw": "http://localhost:3000/register",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["register"]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"João Silva\",\n  \"email\": \"joao@test.com\",\n  \"senha\": \"senha123\"\n}"
            }
          }
        },
        {
          "name": "Fazer Login",
          "request": {
            "method": "POST",
            "url": {
              "raw": "http://localhost:3000/authenticate",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["authenticate"]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"joao@test.com\",\n  \"senha\": \"senha123\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Tarefas",
      "item": [
        {
          "name": "Listar Todas as Tarefas",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:3000/auth/",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["auth", ""]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "{{ token }}"
              }
            ]
          }
        },
        {
          "name": "Buscar Tarefa por ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:3000/auth/tarefa/1",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["auth", "tarefa", "1"]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "{{ token }}"
              }
            ]
          }
        },
        {
          "name": "Criar Tarefa",
          "request": {
            "method": "POST",
            "url": {
              "raw": "http://localhost:3000/auth/tarefa",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["auth", "tarefa"]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "{{ token }}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Implementar feature\"\n}"
            }
          }
        },
        {
          "name": "Atualizar Nome da Tarefa",
          "request": {
            "method": "PUT",
            "url": {
              "raw": "http://localhost:3000/auth/tarefa/1",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["auth", "tarefa", "1"]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "{{ token }}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Implementar feature atualizado\"\n}"
            }
          }
        },
        {
          "name": "Atualizar Status - EM_DESENVOLVIMENTO",
          "request": {
            "method": "PATCH",
            "url": {
              "raw": "http://localhost:3000/auth/tarefa/1/status",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["auth", "tarefa", "1", "status"]
