            "header": [
              {
                "key": "Authorization",
                "value": "{{ token }}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"em_desenvolvimento\"\n}"
            }
          }
        },
        {
          "name": "Atualizar Status - CONCLUIDO",
          "request": {
            "method": "PATCH",
            "url": {
              "raw": "http://localhost:3000/auth/tarefa/1/status",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["auth", "tarefa", "1", "status"]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "{{ token }}"
